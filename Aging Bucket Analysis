# Business Questions & SQL Solutions

## 1. Total Invoices Received

```sql
SELECT COUNT(*) AS Total_Invoices
FROM AR_Analysis;
```

## 2. Total Pending Payments

```sql
SELECT COUNT(*) AS Pending_Invoices
FROM AR_Analysis
WHERE Payment_Status='Unpaid';
```

## 3. Customer with Maximum Unpaid Invoices

```sql
WITH A AS (
SELECT Customer_Name,
       COUNT(*) AS Cnt
FROM AR_Analysis
WHERE Payment_Status='Unpaid'
GROUP BY Customer_Name
),
B AS (
SELECT *,
       DENSE_RANK() OVER(ORDER BY Cnt DESC) AS Rnk
FROM A
)
SELECT *
FROM B
WHERE Rnk=1;
```

## 4. Customer with Maximum Paid Invoices

```sql
WITH A AS (
SELECT Customer_Name,
       COUNT(*) AS Cnt
FROM AR_Analysis
WHERE Payment_Status='Paid'
GROUP BY Customer_Name
),
B AS (
SELECT *,
       DENSE_RANK() OVER(ORDER BY Cnt DESC) AS Rnk
FROM A
)
SELECT *
FROM B
WHERE Rnk=1;
```

## 5. Total Invoice Amount

```sql
SELECT SUM(Inv_Amount) AS Total_Invoice_Amount
FROM AR_Analysis;
```

## 6. Outstanding Receivable Amount

```sql
SELECT SUM(Inv_Amount) AS Outstanding_Amount
FROM AR_Analysis
WHERE Payment_Status='Unpaid';
```

## 7. Total Collected Amount

```sql
SELECT SUM(Inv_Amount) AS Collected_Amount
FROM AR_Analysis
WHERE Payment_Status='Paid';
```

## 8. Average Invoice Amount

```sql
SELECT AVG(Inv_Amount) AS Average_Invoice_Amount
FROM AR_Analysis;
```

## 9. Highest Invoice Amount

```sql
SELECT *
FROM AR_Analysis
WHERE Inv_Amount=
(
SELECT MAX(Inv_Amount)
FROM AR_Analysis
);
```

## 10. Lowest Invoice Amount

```sql
SELECT *
FROM AR_Analysis
WHERE Inv_Amount=
(
SELECT MIN(Inv_Amount)
FROM AR_Analysis
);
```

## 11. Top 5 Highest Invoices

```sql
SELECT *
FROM AR_Analysis
ORDER BY Inv_Amount DESC
LIMIT 5;
```

## 12. Customer-wise Invoice Summary

```sql
SELECT Customer_Name,
       COUNT(*) AS Total_Invoices,
       SUM(Inv_Amount) AS Total_Amount
FROM AR_Analysis
GROUP BY Customer_Name
ORDER BY Total_Amount DESC;
```

## 13. Customer-wise Outstanding Balance

```sql
SELECT Customer_Name,
       SUM(Inv_Amount) AS Outstanding_Amount
FROM AR_Analysis
WHERE Payment_Status='Unpaid'
GROUP BY Customer_Name
ORDER BY Outstanding_Amount DESC;
```

## 14. Customer-wise Collected Amount

```sql
SELECT Customer_Name,
       SUM(Inv_Amount) AS Collected_Amount
FROM AR_Analysis
WHERE Payment_Status='Paid'
GROUP BY Customer_Name
ORDER BY Collected_Amount DESC;
```

## 15. Rank Customers by Revenue

```sql
SELECT Customer_Name,
       SUM(Inv_Amount) AS Revenue,
       DENSE_RANK() OVER
       (ORDER BY SUM(Inv_Amount) DESC) AS Customer_Rank
FROM AR_Analysis
GROUP BY Customer_Name;
```

## 16. Customers with Multiple Invoices

```sql
SELECT Customer_Name,
       COUNT(*) AS Invoice_Count
FROM AR_Analysis
GROUP BY Customer_Name
HAVING COUNT(*) > 1;
```

## 17. Customers Having Both Paid and Unpaid Invoices

```sql
SELECT Customer_Name
FROM AR_Analysis
GROUP BY Customer_Name
HAVING COUNT(DISTINCT Payment_Status)=2;
```

## 18. Running Total of Invoice Amount

```sql
SELECT InvoiceID,
       Invoice_Date,
       Inv_Amount,
       SUM(Inv_Amount)
       OVER(ORDER BY Invoice_Date)
       AS Running_Total
FROM AR_Analysis;
```

## 19. Invoice Category Analysis

```sql
SELECT InvoiceID,
       Customer_Name,
       Inv_Amount,
       CASE
           WHEN Inv_Amount < 5000 THEN 'Low'
           WHEN Inv_Amount BETWEEN 5000 AND 15000 THEN 'Medium'
           ELSE 'High'
       END AS Invoice_Category
FROM AR_Analysis;
```

## 20. Top Revenue Contributing Customer

```sql
WITH Revenue AS (
SELECT Customer_Name,
       SUM(Inv_Amount) AS Revenue
FROM AR_Analysis
GROUP BY Customer_Name
)
SELECT *
FROM Revenue
WHERE Revenue=
(
SELECT MAX(Revenue)
FROM Revenue
);
```

## 21. Latest Invoice

```sql
SELECT *
FROM AR_Analysis
WHERE Invoice_Date=
(
SELECT MAX(Invoice_Date)
FROM AR_Analysis
);
```

## 22. Oldest Invoice

```sql
SELECT *
FROM AR_Analysis
WHERE Invoice_Date=
(
SELECT MIN(Invoice_Date)
FROM AR_Analysis
);
```

## 23. Customer Revenue Contribution %

```sql
SELECT Customer_Name,
       SUM(Inv_Amount) AS Revenue,
       ROUND(
       SUM(Inv_Amount)*100.0/
       (SELECT SUM(Inv_Amount)
        FROM AR_Analysis),2)
       AS Revenue_Percentage
FROM AR_Analysis
GROUP BY Customer_Name
ORDER BY Revenue_Percentage DESC;
```

## 24. Paid vs Unpaid Invoice Distribution

```sql
SELECT Payment_Status,
       COUNT(*) AS Invoice_Count,
       ROUND(
       COUNT(*)*100.0/
       (SELECT COUNT(*) FROM AR_Analysis),2)
       AS Percentage
FROM AR_Analysis
GROUP BY Payment_Status;
```

## 25. Invoice Aging Analysis

```sql
SELECT InvoiceID,
       Customer_Name,
       Invoice_Date,
       Due_Date,
       CURRENT_DATE - Due_Date AS Days_Overdue
FROM AR_Analysis
WHERE Payment_Status='Unpaid';
```

